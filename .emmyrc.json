{
    "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
    "workspace": {
        "library": [
            "$PZ_UMBRELLA"
        ],
        "workspaceRoots": [
            "IconsInventory/mod/42/media/lua",
            "SideBySideContainers/mod/42/media/lua",
            "StaticBags/mod/42/media/lua"
        ]
    },
    "runtime": {
        "requirePattern": [
            "shared/?.lua",
            "client/?.lua",
            "server/?.lua"
        ],
        "version": "Lua5.1"
    },
    "diagnostics": {
        "disable": [
            "unnecessary-if"
        ]
    }
}